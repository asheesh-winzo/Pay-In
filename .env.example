# ============================================================
# Pay-In — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# Docker users: the defaults below already match docker-compose.yml.
# Just copy and run — no changes needed for local Docker development.
#
#   cp .env.example .env.local
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Environment: dev | test | prod
APP_ENV=dev

# Random secret used for signing cookies, CSRF tokens, etc.
# Generate one with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=change_this_to_a_32_char_random_secret

# Base URI used when generating URLs from CLI commands
DEFAULT_URI=http://localhost

# ------------------------------------------------------------
# Database (MySQL)
# ------------------------------------------------------------
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=8.0&charset=utf8mb4
#
# Docker default (matches docker-compose.yml):
DATABASE_URL="mysql://app_user:app_pass@db:3306/pay_in?serverVersion=8.0&charset=utf8mb4"
#
# Local (no Docker):
# DATABASE_URL="mysql://root:root@127.0.0.1:3306/pay_in?serverVersion=8.0&charset=utf8mb4"

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
# Used for: distributed transfer locks + idempotency result caching
#
# Docker default (matches docker-compose.yml):
REDIS_URL="redis://redis:6379"
#
# Local (no Docker):
# REDIS_URL="redis://127.0.0.1:6379"

# ------------------------------------------------------------
# Lock (Symfony Lock component)
# ------------------------------------------------------------
# Used as fallback lock store. In Docker, Redis locks are used
# for transfers. flock is fine for the Symfony internal lock store.
LOCK_DSN=flock
